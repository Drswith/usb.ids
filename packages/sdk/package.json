{
  "name": "@usb-ids/sdk",
  "version": "1.0.1766044584391",
  "description": "Secondary Node/browser SDK for usb.ids.",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "scripts": {
    "lint": "pnpm -C ../.. exec oxlint src tests",
    "typecheck": "pnpm -C ../.. exec tsc --noEmit -p tsconfig.json",
    "test": "pnpm -C ../.. exec vitest run --config vitest.config.ts",
    "build": "pnpm -C ../.. exec tsdown --config tsdown.config.ts --env.NODE_ENV=production"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "browser": "./dist/browser.js",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./browser": {
      "types": "./dist/index.d.ts",
      "import": "./dist/browser.js"
    },
    "./package.json": "./package.json"
  },
  "engines": {
    "node": ">=18"
  }
}
