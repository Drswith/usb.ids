{
  "name": "usb.ids",
  "version": "2.20251213.0",
  "description": "USB IDs CLI and data artifacts package.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Drswith/usb.ids"
  },
  "bin": {
    "usb-ids": "./dist/cli.js"
  },
  "files": [
    "dist",
    "usb.ids",
    "usb.ids.json",
    "usb.ids.version.json"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "browser": "./dist/browser.js"
    },
    "./browser": {
      "types": "./dist/index.d.ts",
      "import": "./dist/browser.js"
    },
    "./data/version": {
      "import": "./dist/version.js",
      "require": "./dist/version.cjs"
    },
    "./data/min": "./dist/data/usb.ids.min.json",
    "./data/compact": "./dist/data/usb.ids.compact.json",
    "./data/vendors-index": "./dist/data/vendors.index.json",
    "./package.json": "./package.json"
  },
  "scripts": {
    "lint": "oxlint src tests",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "pnpm run build && vitest run --config vitest.config.ts",
    "build:lib": "tsdown --config tsdown.config.ts",
    "build:artifacts": "tsx scripts/build-artifacts.ts",
    "build": "pnpm run build:lib && pnpm run build:artifacts",
    "fetch-usb-ids": "tsx src/cli.ts fetch",
    "diff-hash": "tsx scripts/diff-hash.ts",
    "dev:ui": "tsx src/cli.ts ui"
  },
  "dependencies": {
    "commander": "^14.0.2",
    "picocolors": "^1.1.1",
    "prompts": "^2.4.2",
    "sirv": "^2.0.4"
  },
  "devDependencies": {
    "@types/prompts": "^2.4.9",
    "@usb-ids/sdk": "workspace:*",
    "execa": "^9.6.0"
  },
  "engines": {
    "node": ">=18"
  }
}
