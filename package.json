{
  "name": "usb-ids-workspace",
  "version": "0.0.0",
  "private": true,
  "description": "Workspace orchestration for usb.ids monorepo.",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "lint": "pnpm -r --if-present run lint",
    "typecheck": "pnpm -r --if-present run typecheck",
    "test": "pnpm -r --if-present run test",
    "build": "pnpm -r --if-present run build",
    "fetch-usb-ids": "pnpm --filter usb.ids run fetch-usb-ids",
    "diff-hash": "pnpm --filter usb.ids run diff-hash",
    "build:artifacts": "pnpm --filter usb.ids run build:artifacts",
    "openspec": "pnpm dlx @fission-ai/openspec",
    "openspec:list": "pnpm dlx @fission-ai/openspec list",
    "openspec:status": "pnpm dlx @fission-ai/openspec status",
    "openspec:instructions": "pnpm dlx @fission-ai/openspec instructions",
    "openspec:validate": "pnpm dlx @fission-ai/openspec validate --all"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "@vitest/coverage-v8": "^3.2.4",
    "happy-dom": "^18.0.1",
    "oxfmt": "^0.49.0",
    "oxlint": "^1.64.0",
    "tsdown": "^0.14.2",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vite": "^6.2.1",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "pnpm@9.15.9"
}
